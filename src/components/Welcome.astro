---
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<div class="container">
	<header class="blog-header">
		<h1 class="blog-title">Data & AI Horizon</h1>
		<p class="blog-subtitle">生成AI×データサイエンス</p>
	</header>

	<section class="profile-section card">
		<h2>運営者 hiro のプロフィール</h2>
		<p>データサイエンスと生成AIを専門とするhiroです。このブログでは、最新のAI技術からデータ分析のノウハウまで、幅広く情報発信していきます。</p>
	</section>

	<section class="latest-posts-section">
		<h2>新着記事一覧</h2>
		<div class="post-cards">
			{sortedPosts.map((post) => (
				<article class="post-card">
					<h3><a href={`/blog/${post.slug}`}>{post.data.title}</a></h3>
					<p>{post.data.pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: '2-digit', day: '2-digit' })}</p>
				</article>
			))}
		</div>
	</section>
</div>

<style>
	/* デフォルトはダークモード */
	:root {
		--bg-color: #20232a; /* 深いチャコールグレー */
		--text-color: #e0e0e0; /* 明るいグレー */
		--primary-color: #00bcd4; /* ネオンブルーのアクセントカラー */
		--card-bg-color: #2d333b; /* カードの背景色 */
		--border-color: #444951; /* カードや要素のボーダー色 */
		--shadow-color: rgba(0, 0, 0, 0.4); /* 暗い影 */
	}

	/* ライトモードの場合のスタイル上書き */
	@media (prefers-color-scheme: light) {
		:root {
			--bg-color: #ffffff; /* 清潔感のある白 */
			--text-color: #333333; /* 濃いグレー */
			--primary-color: #007bff; /* 標準的な青のアクセントカラー */
			--card-bg-color: #f8f9fa; /* カードの背景色 */
			--border-color: #e0e0e0; /* カードや要素のボーダー色 */
			--shadow-color: rgba(0, 0, 0, 0.05); /* 薄い影 */
		}
	}

	body {
		margin: 0;
		padding: 0;
		background-color: var(--bg-color);
		color: var(--text-color);
		font-family: 'Roboto', 'Noto Sans JP', 'Segoe UI', 'Helvetica Neue', Arial, sans-serif, 'Apple Color Emoji', 'Segoe UI Emoji', 'Segoe UI Symbol';
		line-height: 1.6;
		transition: background-color 0.3s ease, color 0.3s ease;
	}

	.container {
		max-width: 1000px;
		margin: 0 auto;
		padding: 3rem 1.5rem;
	}

	.blog-header {
		text-align: center;
		margin-bottom: 4rem;
		padding-top: 2rem;
	}

	.blog-title {
		font-size: 4.5rem;
		font-weight: 800;
		margin: 0;
		color: var(--primary-color);
		letter-spacing: -0.08em;
		text-shadow: 0 0 15px var(--primary-color), 0 0 30px var(--primary-color);
		transition: color 0.3s ease, text-shadow 0.3s ease;
	}

	.blog-subtitle {
		font-size: 1.8rem;
		color: var(--text-color);
		margin-top: 1rem;
		opacity: 0.8;
		font-weight: 300;
	}

	section {
		margin-bottom: 4rem;
	}

	h2 {
		font-size: 2.2rem;
		font-weight: 700;
		margin-bottom: 2rem;
		color: var(--text-color);
		position: relative;
		padding-bottom: 0.8rem;
	}

	h2::after {
		content: '';
		position: absolute;
		left: 0;
		bottom: 0;
		width: 80px;
		height: 4px;
		background-color: var(--primary-color);
		border-radius: 2px;
	}

	.card {
		background-color: var(--card-bg-color);
		border-radius: 15px;
		padding: 2.5rem;
		box-shadow: 0 8px 25px var(--shadow-color);
		border: 1px solid var(--border-color);
		transition: background-color 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
	}

	.profile-section p {
		font-size: 1.15rem;
		line-height: 1.9;
		color: var(--text-color);
	}

	.latest-posts-section .post-cards {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2rem;
	}

	.post-card {
		background-color: var(--card-bg-color);
		border-radius: 15px;
		padding: 2rem;
		box-shadow: 0 4px 15px var(--shadow-color);
		border: 1px solid var(--border-color);
		transition: transform 0.3s ease-in-out, box-shadow 0.3s ease-in-out, background-color 0.3s ease, border-color 0.3s ease;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
	}

	.post-card:hover {
		transform: translateY(-8px);
		box-shadow: 0 12px 25px var(--shadow-color);
	}

	.post-card h3 {
		font-size: 1.5rem;
		font-weight: 700;
		margin-top: 0;
		margin-bottom: 1rem;
		color: var(--primary-color);
		line-height: 1.4;
	}

	.post-card p {
		font-size: 1rem;
		color: var(--text-color);
		opacity: 0.7;
		margin-bottom: 0;
	}

	/* レスポンシブデザイン */
	@media (max-width: 768px) {
		.container {
			padding: 2rem 1rem;
		}

		.blog-title {
			font-size: 3.5rem;
		}

		.blog-subtitle {
			font-size: 1.5rem;
		}

		h2 {
			font-size: 1.8rem;
			margin-bottom: 1.5rem;
		}

		h2::after {
			width: 60px;
			height: 3px;
		}

		.card {
			padding: 2rem;
		}

		.profile-section p {
			font-size: 1.05rem;
		}

		.latest-posts-section .post-cards {
			grid-template-columns: 1fr; /* スマホでは縦並び */
		}

		.post-card {
			padding: 1.5rem;
		}

		.post-card h3 {
			font-size: 1.25rem;
		}

		.post-card p {
			font-size: 0.9rem;
		}
	}

	@media (max-width: 480px) {
		.container {
			padding: 1.5rem 0.8rem;
		}

		.blog-title {
			font-size: 2.8rem;
			letter-spacing: -0.05em;
		}

		.blog-subtitle {
			font-size: 1.2rem;
		}

		h2 {
			font-size: 1.5rem;
		}
	}
</style>
